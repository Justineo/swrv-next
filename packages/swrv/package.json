{
  "name": "swrv",
  "version": "0.0.0",
  "description": "Vue-native stale-while-revalidate data fetching",
  "keywords": [
    "cache",
    "data-fetching",
    "stale-while-revalidate",
    "swr",
    "swrv",
    "vue"
  ],
  "homepage": "https://github.com/Kong/swrv",
  "bugs": {
    "url": "https://github.com/Kong/swrv/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kong/swrv.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./_internal": "./dist/_internal/index.mjs",
    "./immutable": "./dist/immutable/index.mjs",
    "./infinite": "./dist/infinite/index.mjs",
    "./mutation": "./dist/mutation/index.mjs",
    "./subscription": "./dist/subscription/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack src/index.ts src/infinite/index.ts src/mutation/index.ts src/subscription/index.ts src/immutable/index.ts src/_internal/index.ts",
    "check": "vp check",
    "dev": "vp pack src/index.ts src/infinite/index.ts src/mutation/index.ts src/subscription/index.ts src/immutable/index.ts src/_internal/index.ts --watch",
    "test": "vp test"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "vue": "catalog:"
  }
}
