{
  "name": "swrv-next",
  "version": "2.0.0-next.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run build -r",
    "check": "vp check",
    "dev": "vp run site#dev",
    "ready": "vp check && vp run test -r && vp run build -r && vp exec playwright test",
    "release:verify": "vp run ready && vp run swrv#release:verify",
    "release:major": "vp exec bumpp --all --recursive --commit --tag --push --yes --release major",
    "release:minor": "vp exec bumpp --all --recursive --commit --tag --push --yes --release minor",
    "release:patch": "vp exec bumpp --all --recursive --commit --tag --push --yes --release patch",
    "test": "vp run test -r",
    "test:e2e": "vp exec playwright test",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "bumpp": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.2"
}
